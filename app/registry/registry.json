{
  "doclens": {
    "collection": "doclens",
    "ingestion": {
      "strategy": "semantic_doc",
      "max_tokens": 512,
      "min_tokens": 50,
      "overlap_tokens": 64,
      "semantic_split": true
    },
    "embedding": {
      "model": "BAAI/bge-small-en",
      "batch_size": 32,
      "normalize": true
    },
    "retrieval": {
      "top_k": 10,
      "hybrid": true,
      "alpha": 0.7
    },
    "reranking": {
      "enabled": true,
      "model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "top_k": 5,
      "candidate_cap": 20
    },
    "generation": {
      "response_type": "markdown",
      "temperature": 0.1,
      "strict": false,
      "max_retries": 2
    },
    "defaults": {
      "system_prompt": "You are DocLens, a document intelligence assistant. Answer only from the retrieved context. Format your response in clear markdown. If the answer is not present in the context, say so explicitly."
    }
  },
  "resumelab": {
    "collection": "resume_memory",
    "ingestion": {
      "strategy": "resume_canonical",
      "max_tokens": 512,
      "min_tokens": 30,
      "overlap_tokens": 0,
      "semantic_split": false
    },
    "embedding": {
      "model": "BAAI/bge-small-en",
      "batch_size": 32,
      "normalize": true
    },
    "retrieval": {
      "top_k": 12,
      "hybrid": true,
      "alpha": 0.7
    },
    "reranking": {
      "enabled": true,
      "model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "top_k": 6,
      "candidate_cap": 24
    },
    "generation": {
      "response_type": "json",
      "temperature": 0.05,
      "strict": true,
      "max_retries": 3
    },
    "defaults": {
      "system_prompt": "You are a structured career intelligence engine. Extract, normalize, and organize professional experience with factual accuracy."
    },
    "default_task": "match",
    "tasks": {
      "match": {
        "system_prompt": "You are a structured career intelligence engine. Analyze the job description against the candidate's canonical profile and current resume. Return ONLY valid JSON. You MUST distinguish: (A) keywords the candidate lacks entirely vs. (B) keywords they have in their profile but omitted from the current resume. Never guess—use the pre-computed keyword analysis provided in the context.",
        "response_type": "json",
        "schema": {
          "type": "object",
          "required": [
            "match_score",
            "required_keywords",
            "missing_keywords",
            "existing_but_missing_from_resume",
            "irrelevant_content",
            "recommended_additions",
            "recommended_removals",
            "section_rewrites",
            "ats_keyword_clusters",
            "role_seniority",
            "domain_fit"
          ],
          "properties": {
            "match_score": {"type": "number"},
            "required_keywords": {"type": "array", "items": {"type": "string"}},
            "missing_keywords": {"type": "array", "items": {"type": "string"}},
            "existing_but_missing_from_resume": {"type": "array", "items": {"type": "string"}},
            "irrelevant_content": {"type": "array", "items": {"type": "string"}},
            "recommended_additions": {"type": "array", "items": {"type": "string"}},
            "recommended_removals": {"type": "array", "items": {"type": "string"}},
            "section_rewrites": {"type": "object"},
            "ats_keyword_clusters": {"type": "object"},
            "role_seniority": {"type": "string"},
            "domain_fit": {"type": "string"}
          }
        },
        "strict": true,
        "max_retries": 3,
        "temperature": 0.05
      },
      "generate": {
        "system_prompt": "You are a structured career intelligence engine. Generate ATS-optimized resume content blocks from the candidate's canonical profile for the target role. Return ONLY valid JSON. CRITICAL: Never fabricate skills, experience, metrics, company names, titles, or dates not present in the canonical profile. Every claim must be grounded in the provided profile data.",
        "response_type": "json",
        "schema": {
          "type": "object",
          "required": [
            "summary",
            "skills",
            "projects",
            "experience",
            "target_keywords_used",
            "removed_content",
            "match_score_improved"
          ],
          "properties": {
            "summary": {"type": "string"},
            "skills": {"type": "array", "items": {"type": "string"}},
            "projects": {"type": "array"},
            "experience": {"type": "array"},
            "target_keywords_used": {"type": "array", "items": {"type": "string"}},
            "removed_content": {"type": "array", "items": {"type": "string"}},
            "match_score_improved": {"type": "number"}
          }
        },
        "strict": true,
        "max_retries": 3,
        "temperature": 0.05
      }
    }
  },
  "cvscan": {
    "collection": "cvscan",
    "ingestion": {
      "strategy": "resume_structured",
      "max_tokens": 256,
      "min_tokens": 30,
      "overlap_tokens": 0,
      "semantic_split": false
    },
    "embedding": {
      "model": "BAAI/bge-small-en",
      "batch_size": 32,
      "normalize": true
    },
    "retrieval": {
      "top_k": 15,
      "hybrid": true,
      "alpha": 0.6
    },
    "reranking": {
      "enabled": true,
      "model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
      "top_k": 8,
      "candidate_cap": 30
    },
    "generation": {
      "response_type": "json",
      "temperature": 0.05,
      "strict": true,
      "max_retries": 3
    },
    "defaults": {
      "system_prompt": "You are CVScan, a professional resume analysis assistant. Analyze the provided context and return ONLY valid JSON matching the required schema."
    },
    "default_task": "resume_match",
    "tasks": {
      "resume_match": {
        "system_prompt": "You are CVScan. Analyze the resume against the job description and return ONLY valid JSON. Always include every required field. Use empty string for missing strings, [] for missing arrays, 0 for missing numbers.",
        "response_type": "json",
        "schema": {
          "type": "object",
          "required": ["candidate_name", "score", "strengths", "weaknesses", "missing_keywords", "summary"],
          "properties": {
            "candidate_name": {"type": "string"},
            "score": {"type": "number"},
            "strengths": {"type": "array", "items": {"type": "string"}},
            "weaknesses": {"type": "array", "items": {"type": "string"}},
            "missing_keywords": {"type": "array", "items": {"type": "string"}},
            "summary": {"type": "string"}
          }
        },
        "strict": true
      },
      "resume_extract": {
        "system_prompt": "You are CVScan. Extract all resume details from the context and return ONLY valid JSON.",
        "response_type": "json",
        "schema": {
          "type": "object",
          "required": ["candidate_name", "contact", "summary", "skills", "experience", "education", "certifications", "projects"],
          "properties": {
            "candidate_name": {"type": "string"},
            "contact": {"type": "object"},
            "summary": {"type": "string"},
            "skills": {"type": "array", "items": {"type": "string"}},
            "experience": {"type": "array"},
            "education": {"type": "array"},
            "certifications": {"type": "array", "items": {"type": "string"}},
            "projects": {"type": "array"}
          }
        },
        "strict": true
      },
      "gap_analysis": {
        "system_prompt": "You are CVScan. Perform a detailed gap analysis between the resume and job requirements and return ONLY valid JSON.",
        "response_type": "json",
        "schema": {
          "type": "object",
          "required": ["matching_skills", "missing_skills", "strengths", "gaps", "recommendations", "confidence"],
          "properties": {
            "matching_skills": {"type": "array", "items": {"type": "string"}},
            "missing_skills": {"type": "array", "items": {"type": "string"}},
            "strengths": {"type": "array", "items": {"type": "string"}},
            "gaps": {"type": "array", "items": {"type": "string"}},
            "recommendations": {"type": "array", "items": {"type": "string"}},
            "confidence": {"type": "number"}
          }
        },
        "strict": true
      },
      "resume_generate_structured": {
        "system_prompt": "You are CVScan. Generate an optimized structured resume output from the provided context and return ONLY valid JSON.",
        "response_type": "json",
        "schema": {
          "type": "object",
          "required": ["headline", "summary", "skills", "experience_bullets", "education", "certifications", "projects"],
          "properties": {
            "headline": {"type": "string"},
            "summary": {"type": "string"},
            "skills": {"type": "array", "items": {"type": "string"}},
            "experience_bullets": {"type": "array", "items": {"type": "string"}},
            "education": {"type": "array"},
            "certifications": {"type": "array", "items": {"type": "string"}},
            "projects": {"type": "array"}
          }
        },
        "strict": true
      }
    }
  }
}
