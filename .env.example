# ============================================================
# Cortex RAG Engine — Environment Variables
# Copy to .env and fill in values for your deployment.
# ============================================================

# ---------------------------------------------------------------------------
# Application environment
# ---------------------------------------------------------------------------
# Set to "development", "dev", or "local" to enable /docs, /redoc, /openapi.json
# Any other value (or unset) disables docs — production fails closed.
APP_ENV=development

# ---------------------------------------------------------------------------
# Qdrant vector store
# ---------------------------------------------------------------------------
QDRANT_MODE=local           # "local" or "cloud"
QDRANT_HOST=localhost       # local mode only
QDRANT_PORT=6333            # local mode only
QDRANT_URL=                 # cloud mode: https://your-cluster.qdrant.tech
QDRANT_API_KEY=             # cloud mode

# ---------------------------------------------------------------------------
# LLM provider (BYOK — required for production)
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama_cloud   # "openai" | "ollama_cloud" | "ollama_local"
LLM_MODEL=                  # leave blank for provider defaults

OPENAI_API_KEY=
OLLAMA_CLOUD_API_KEY=
OLLAMA_TIMEOUT=600          # seconds; local models on large prompts can be slow

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Admin key for /admin/*, /apps/*, /collections/*, /metrics endpoints.
# Missing in production → 503 (fail closed). Set a strong random value.
ADMIN_API_KEY=

# JWT verification (at least one must be set for production auth)
# Use CORTEX_JWT_SECRET when trusted app backends sign HS256 service tokens.
CORTEX_JWT_SECRET=          # strong shared secret; keep server-side only
JWT_PUBLIC_KEY=             # RS256/ES256 public key PEM
JWT_JWKS_URL=               # JWKS endpoint URL (e.g. https://your-auth.example.com/.well-known/jwks.json)

# CORS (comma-separated origin patterns, supports *.domain.com wildcards)
CORS_ALLOWED_ORIGINS=https://*.jayprajapati.dev,http://localhost:5173,http://localhost:3000,http://localhost:8000

# Trusted hosts (comma-separated, supports *.domain.com wildcards)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*.jayprajapati.dev

# Docs block host allowlist (for BlockDocsInProduction middleware)
DOCS_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Signed-nonce anti-Postman layer (off by default; set to "true" to enable)
ENABLE_REQUEST_NONCE=false

# ---------------------------------------------------------------------------
# File upload limits
# ---------------------------------------------------------------------------
MAX_UPLOAD_BYTES=26214400   # 25 MB default

# ---------------------------------------------------------------------------
# Ingestion / OCR
# ---------------------------------------------------------------------------
LOADER_TIMEOUT=60           # seconds before Docling conversion times out
OCR_TEXT_THRESHOLD=50       # avg chars/page below which OCR is triggered
INSPECTOR_IMAGE_THRESHOLD=2 # pages with > N images → complex document
INSPECTOR_PAGE_THRESHOLD=30 # > N pages → complex document

# ---------------------------------------------------------------------------
# ResumeLab
# ---------------------------------------------------------------------------
RESUME_EXTRACT_CACHE_SIZE=50     # in-memory LRU cache size for extraction results
RESUMELAB_MAX_TEXT_CHARS=8000    # max chars fed to LLM for resume extraction/generation

# ---------------------------------------------------------------------------
# Conversation / threading
# ---------------------------------------------------------------------------
KEEP_RECENT=10              # message turns always kept verbatim in prompt
SUMMARIZE_AFTER=10          # trigger summarization after N messages past KEEP_RECENT
AUTO_TITLE_MAX_WORDS=8      # max words in auto-generated thread titles

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
AUDIT_LOG_PATH=audit.log    # path for audit log (ingest, delete, admin actions)
SENTRY_DSN=                 # Sentry DSN — leave blank to disable Sentry
SENTRY_TRACES_SAMPLE_RATE=0.1
